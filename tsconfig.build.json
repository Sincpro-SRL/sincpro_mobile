{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "./lib",
    "rootDir": "./sincpro_mobile",
    "jsx": "react-jsx",
    "jsxImportSource": "nativewind",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "sourceMap": false,
    "declarationMap": false
  },
  "include": ["sincpro_mobile/**/*.ts", "sincpro_mobile/**/*.tsx"],
  "exclude": ["node_modules", "lib", "**/__tests__", "**/*.test.*"]
}
